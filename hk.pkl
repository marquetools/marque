amends "package://github.com/jdx/hk/releases/download/v1.41.1/hk@1.41.1#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.41.1/hk@1.41.1#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  ["actionlint"] = Builtins.actionlint
  ["biome"] = Builtins.biome
  ["cargo_clippy"] = Builtins.cargo_clippy
  ["cargo_fmt"] = Builtins.cargo_fmt
  ["check_added_large_files"] = Builtins.check_added_large_files
  ["check_byte_order_marker"] = Builtins.check_byte_order_marker
  ["check_conventional_commit"] = Builtins.check_conventional_commit
  ["check_executables_have_shebangs"] = Builtins.check_executables_have_shebangs
  ["check_merge_conflict"] = Builtins.check_merge_conflict
  ["check_symlinks"] = Builtins.check_symlinks
  ["contextlint"] = Builtins.contextlint
  ["detect_private_key"] = Builtins.detect_private_key
  ["fix_byte_order_marker"] = Builtins.fix_byte_order_marker
  ["fix_smart_quotes"] = Builtins.fix_smart_quotes
  ["mixed_line_ending"] = Builtins.mixed_line_ending
  ["pkl"] = Builtins.pkl
  ["pkl_format"] = Builtins.pkl_format
  ["shellcheck"] = Builtins.shellcheck
  ["shfmt"] = Builtins.shfmt
  ["sort_package_json"] = Builtins.sort_package_json
  ["tombi"] = Builtins.tombi
  ["typos"] = Builtins.typos
  ["yq"] = Builtins.yq
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }
  ["check"] {
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
}
