{
    "@context": {
        "@vocab": "urn:us:gov:ic:cve#", 
        "ism": "urn:us:gov:ic:ism#"
    }, 
    "CVE": {
        "ism:ownerProducer": "USA", 
        "CVEVersion": "2.1", 
        "specVersion": "202111.202211", 
        "ism:DESVersion": "202111", 
        "xsi:schemaLocation": "urn:us:gov:ic:cve ../CveSchema/CVEXml.xsd", 
        "Enumeration": {
            "Term": [
                {
                    "Description": {
                        "text": "Document claims compliance with all rules encoded in ISM for documents produced by the US Federal Government. This is the minimum set of rules for US documents to adhere to, and all US documents should claim compliance with USGov. For example, a US Intelligence Community document should claim ism:compliesWith=\"USGov USIC\".", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "USGov", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }, 
                {
                    "Description": {
                        "text": "Document claims compliance with all rules encoded in ISM for documents produced by the US Intelligence Community. Documents that claim compliance with USIC MUST also claim compliance with USGov.", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "USIC", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }, 
                {
                    "Description": {
                        "text": "Document claims compliance with all rules encoded in ISM for documents produced by the US Department of Defense. Documents that claim compliance with USDOD MUST also claim compliance with USGov.", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "USDOD", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }, 
                {
                    "Description": {
                        "text": "Document claims compliance with an authority other than the USGov, USIC, or USDOD. This token is not allowed if the ism:ownerProducer contains USA.", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "OtherAuthority", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }, 
                {
                    "Description": {
                        "text": "Document is UNCLASSIFIED and was created in an UNCLASSIFIED environment. Document claims compliance with CUI rules but with no USGOV rules for classified environments. Special transforms are required to move the document into a classified environment or to commingle content from this document with any content created in a classified environment.", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "USA-CUI-ONLY", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }, 
                {
                    "Description": {
                        "text": "Document contains both NSI (National Security Information) and CUI according to DoD rules for CUI. Document claims compliance with 1. CUI rules according to DoD, and 2. USGOV and/or USDOD rules for classified environments.", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:ownerProducer": "USA", 
                    "Value": {
                        "text": "USA-CUI", 
                        "ism:ownerProducer": "USA", 
                        "ism:classification": "U"
                    }, 
                    "ism:classification": "U"
                }
            ], 
            "multivalue": "true", 
            "ism:ownerProducer": "USA", 
            "ism:classification": "U"
        }, 
        "ism:compliesWith": "USGov USIC", 
        "IRM": {
            "PointOfContact": {
                "Email": "ic-standards-support@odni.gov", 
                "Name": "Office IC CIO", 
                "ism:ownerProducer": "USA", 
                "ism:classification": "U"
            }, 
            "Created": "2010-05-30T16:52:00-04:00", 
            "URN": "urn:us:gov:ic:cvenum:ism:complieswith", 
            "Title": {
                "text": "CVEnumISMCompliesWith", 
                "ism:ownerProducer": "USA", 
                "ism:classification": "U"
            }, 
            "Source": {
                "text": "ISM schema", 
                "ism:ownerProducer": "USA", 
                "ism:classification": "U"
            }, 
            "Description": {
                "text": "ISM rule sets documents may comply with. This CVE is used by @ism:compliesWith.", 
                "ism:ownerProducer": "USA", 
                "ism:classification": "U"
            }
        }, 
        "ism:classification": "U", 
        "ism:createDate": "2011-09-01", 
        "ism:resourceElement": "true", 
        "ism:ISMCATCESVersion": "202205"
    }
