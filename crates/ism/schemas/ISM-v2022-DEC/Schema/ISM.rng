      <data type="boolean"/>
    </attribute>
  </define>
  
  <define name="exemptFrom.att" combine="interleave">
    <attribute name="ism:exemptFrom">
      <ref name="CVEnumISMExemptFrom.cve"/>
    </attribute>
  </define>
  
