  <define name="DESVersion.att" combine="interleave">
    <attribute name="ism:DESVersion">
      <data type="string">
        <param name="pattern">[0-9]{6}(\.[0-9]{6})?(\-.{1,23})?</param>
      </data>
    </attribute>
  </define>
  
  <define name="displayOnlyTo.att" combine="interleave">
