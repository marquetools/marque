<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" targetNamespace="test:arh"
           xmlns:ntk="urn:us:gov:ic:ntk" 
           xmlns:ism="urn:us:gov:ic:ism" 
           xmlns:arh="urn:us:gov:ic:arh"
           xmlns:test="test:arh">
   <xs:import namespace="urn:us:gov:ic:ntk"
              schemaLocation="../../Schema/ISM/IC-NTK.xsd"/>
   <xs:import namespace="urn:us:gov:ic:ism"
              schemaLocation="../../Schema/ISM/IC-ISM.xsd"/>
   <xs:import namespace="urn:us:gov:ic:arh"
              schemaLocation="../../Schema/ISM/IC-ARH.xsd"/>
   <xs:element name="root">
      <xs:complexType>
         <xs:sequence>
            <xs:choice>
               <xs:element ref="arh:Security" minOccurs="1" maxOccurs="1"/>
               <xs:element ref="arh:ExternalSecurity" minOccurs="1" maxOccurs="1"/>
            </xs:choice>
         </xs:sequence>
         <xs:attribute ref="arh:DESVersion" use="optional"/>
         <xs:attribute ref="ism:DESVersion" use="optional"/>
         <xs:attribute ref="ism:ISMCATCESVersion"/>
         <xs:attribute ref="ntk:DESVersion" use="optional"/>
         <xs:attributeGroup ref="ism:ISMResourceAttributeOptionGroup"/>
         <xs:attributeGroup ref="ism:SecurityAttributesOptionGroup"/>
      </xs:complexType>
   </xs:element>
</xs:schema>
