# Supply chain audit finding C1: harden npm against common attack vectors.

# Prevent transitive dependencies from executing install lifecycle hooks
# (postinstall, preinstall, etc.) — the most common npm supply chain vector.
ignore-scripts=true

# Run `npm audit` automatically on install to surface known vulnerabilities.
audit=true

# Enforce lockfile use — prevent accidental installs without package-lock.json.
package-lock=true
